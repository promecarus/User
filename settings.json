{
	"[blade]": {
		"editor.defaultFormatter": "shufo.vscode-blade-formatter"
	},
	"[css]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[java]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[json]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[php]": {
		"editor.defaultFormatter": "kokororin.vscode-phpfmt"
	},
	"[python]": {
		"editor.defaultFormatter": "ms-python.black-formatter",
		"editor.formatOnSave": true,
		"editor.insertSpaces": true,
		"editor.tabSize": 4
	},
	"[svelte]": {
		"editor.defaultFormatter": "svelte.svelte-vscode"
	},
	"bladeFormatter.format.indentSize": 1,
	"bladeFormatter.format.sortHtmlAttributes": "alphabetical",
	"bladeFormatter.format.sortTailwindcssClasses": true,
	"bladeFormatter.format.useTabs": true,
	"diffEditor.ignoreTrimWhitespace": false,
	"editor.cursorBlinking": "expand",
	"editor.cursorSmoothCaretAnimation": true,
	"editor.cursorStyle": "line",
	"editor.defaultFormatter": null,
	"editor.fontFamily": "Fira Code, Consolas, 'Courier New', monospace",
	"editor.fontLigatures": true,
	"editor.fontWeight": 1,
	"editor.formatOnType": false,
	"editor.guides.bracketPairs": "active",
	"editor.inlineSuggest.enabled": true,
	"editor.largeFileOptimizations": false,
	"editor.minimap.enabled": false,
	"editor.minimap.side": "left",
	"editor.renderControlCharacters": true,
	"editor.suggestSelection": "first",
	"editor.wordWrap": "on",
	"emmet.includeLanguages": {
		"django-html": "html",
		"postcss": "css"
	},
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"files.associations": {
		"*.css": "css",
		"*.html": "html"
	},
	"files.insertFinalNewline": true,
	"git.autofetch": true,
	"git.confirmSync": false,
	"github.copilot.enable": {
		"*": true,
		"yaml": false
	},
	"liveshare.accessibility.soundsEnabled": false,
	"liveshare.allowGuestDebugControl": true,
	"liveshare.allowGuestTaskControl": true,
	"liveshare.languages.allowGuestCommandControl": true,
	"mdb.confirmRunAll": false,
	"php.validate.executablePath": "C:\\xampp\\php\\php.exe",
	"phpfmt.cakephp": true,
	"prettier.printWidth": 200,
	"prettier.tabWidth": 4,
	"prettier.useTabs": true,
	"python.formatting.blackArgs": [
		"-l 120"
	],
	"redhat.telemetry.enabled": false,
	"security.workspace.trust.untrustedFiles": "open",
	"settingsSync.ignoredSettings": [
		"-python.formatting.blackPath"
	],
	"svelte.enable-ts-plugin": true,
	"terminal.integrated.copyOnSelection": true,
	"terminal.integrated.defaultProfile.windows": "Git Bash",
	"vsicons.dontShowNewVersionMessage": true,
	"window.restoreWindows": "none",
	"window.zoomLevel": -1,
	"workbench.colorTheme": "One Dark Pro Flat",
	"workbench.editor.labelFormat": "short",
	"workbench.editorAssociations": {
		"*.sql": "default"
	},
	"workbench.iconTheme": "vscode-icons",
	"workbench.sideBar.location": "right",
	"workbench.startupEditor": "none"
}
